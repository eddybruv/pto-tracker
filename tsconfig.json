{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./server/dist",
    "rootDir": "./server/src"
  },
  "include": ["server/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
